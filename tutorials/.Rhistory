library(patchwork)
plot1 = ggplot(df) +
geom_line(aes(Date, Value, colour = Type), linewidth=0.4, color='#4393C3') +
gghighlight(max(Value) > 10,
unhighlighted_params = list(linewidth = 0.3,
colour = alpha("darkred", 0.7),
linetype = "dotted"),
use_direct_label = FALSE) +
theme_bw() + xlab("") + ylab("")
